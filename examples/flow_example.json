    {"id": "e_phone_retry",                       "source": "node_collect_phone_number",  "target": "node_collect_phone_number",  "output": "retry"},
    {"id": "e_phone_escalate",                    "source": "node_collect_phone_number",  "target": "node_escalate",              "output": "escalate"},

    {"id": "e_address_collected",                 "source": "node_collect_address",       "target": "node_collect_reason",        "output": "collected"},
    {"id": "e_address_retry",                     "source": "node_collect_address",       "target": "node_collect_address",       "output": "retry"},
